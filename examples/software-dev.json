  "contenu": {
    "type": "erreur",
    "gravite": "critique",
    "description": "Utilisation de l'algorithme HS256 sans rotation de clé secrète. Si le secret est compromis, tous les tokens émis restent valides jusqu'à expiration, sans possibilité de révocation immédiate.",
    "solution": "Utiliser RS256 (asymétrique) avec rotation automatique des clés privées toutes les 24h via un KMS (Key Management Service). En cas de compromission, seule la clé privée doit être révoquée.",
    "exemple": {
      "langage": "python",
      "code_problematique": "import jwt\ntoken = jwt.encode(payload, 'mon_secret_hardcode', algorithm='HS256')",
      "code_corrige": "from authlib.jose import JsonWebKey, jwt\nprivate_key = kms.get_current_key()\ntoken = jwt.encode({'alg': 'RS256'}, payload, private_key)"
    }
  },

