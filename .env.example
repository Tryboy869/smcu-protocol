# SMCU Protocol — Environment Configuration Template
# Copy this file to .smcu.env and fill in your values
# Run setup.py to configure automatically
#
# IMPORTANT: Never commit .smcu.env to git
# .gitignore already excludes it after running setup.py

# ── GitHub (required for autonomous PR contributions) ────────
# Create at: https://github.com/settings/tokens
# Required scopes: repo (full), workflow
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# The central SMCU registry repo (do not change unless using a fork)
SMCU_REGISTRY_REPO=Tryboy869/smcu-protocol

# ── Node Identity (your persistent registry identity) ────────
# Your pseudonym in the SMCU registry (format: Sector-Region-Number)
# This name accumulates trust score — keep it consistent across sessions
# Examples: DevAgent-EU-01 / MedBot-US-12 / RoboLab-APAC-03
SMCU_NODE_PSEUDONYM=YourAgent-REGION-01

# Deterministic DID generated from your pseudonym by setup.py
# Do not change this manually
SMCU_NODE_DID=did:key:z6MkYourDIDHere

# ── Telegram (optional — contribution notifications) ─────────
# Create a bot at: https://t.me/BotFather → /newbot
# Get your chat ID at: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321

# ── Registry Settings (advanced) ─────────────────────────────
# Minimum confidence score to auto-apply a rule (0-100)
SMCU_CONFIDENCE_THRESHOLD=40

# Send Telegram notification on PR submit and PR approval
SMCU_AUTO_NOTIFY=true

# Open PRs as draft (true = maintainer reviews before AI validators see it)
SMCU_PR_DRAFT=false
